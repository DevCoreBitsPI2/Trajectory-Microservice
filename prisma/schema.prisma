generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model career_history {
  id_record               Int                      @id @default(autoincrement())
  description             String
  event_date              DateTime                 @db.Date
  type                    career_history_type
  id_employee             Int
  created_at              DateTime                 @default(dbgenerated("CURRENT_DATE")) @db.Date
  id_evaluation           Int?
  performance_evaluations performance_evaluations? @relation(fields: [id_evaluation], references: [id_evaluation], onDelete: NoAction)
}

model performance_evaluations {
  id_evaluation         Int              @id @default(autoincrement())
  id_director           Int
  observations          String?
  evaluation_date       DateTime         @db.Date
  created_at            DateTime         @default(dbgenerated("CURRENT_DATE")) @db.Date
  communication         Float            @default(0) @db.Real
  technical_proficiency Float            @default(0) @db.Real
  leadership_influence  Float            @default(0) @db.Real
  innovation            Float            @default(0) @db.Real
  reliability           Float            @default(0) @db.Real
  career_history        career_history[]
}

enum career_history_type {
  promotion
  transfer
  contract_modification
  salary_change
  evaluation
}
