{
    "moduleFileExtensions":  [
                                 "js",
                                 "json",
                                 "ts"
                             ],
    "rootDir":  ".",
    "testMatch":  [
                      "**/test/steps/**/*.steps.ts"
                  ],
    "transform":  {
                      "^.+\\.(t|j)s$":  "ts-jest"
                  },
    "collectCoverageFrom":  [
                                "src/**/*.(t|j)s"
                            ],
    "coverageDirectory":  "coverage-bdd",
    "testEnvironment":  "node",
    "moduleNameMapper":  {
                             "^@/(.*)$":  "\u003crootDir\u003e/../$1"
                         }
}
